		"@tsconfig/node24": "^24.0.4",
		"@types/node": "^24.10.9",
		"@vitejs/plugin-vue": "^6.0.3",
		"@vue/tsconfig": "^0.8.1",
		"npm-run-all2": "^8.0.4",
		"oxfmt": "^0.33.0",
		"oxlint": "^1.48.0",
		"postcss": "^8.5.6",
